# Copy to .env and fill in. NEVER commit .env — only this template.
# Every value here is validated by src/config/env.ts at boot; a bad value stops
# the process immediately rather than failing on the first request.

NODE_ENV=development
PORT=4000

# PostgreSQL. The hostname is `postgres` (the compose service name) when the API
# runs inside Docker, and `localhost` when you run `bun dev` on the host.
DATABASE_URL=postgresql://assetflow:assetflow@localhost:5432/assetflow

# Must be at least 32 characters. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=604800

# Comma-separated browser origins allowed to call this API.
# Add your Vercel URL here when the frontend is deployed.
CORS_ORIGINS=http://localhost:3000
