# Root .env — read by docker-compose.yml ONLY (the API's own config lives in
# backend/.env; see backend/.env.example).
#
#   cp .env.example .env    then fill in JWT_SECRET
#
# NEVER commit .env.

POSTGRES_USER=assetflow
POSTGRES_PASSWORD=assetflow
POSTGRES_DB=assetflow

NODE_ENV=production

# Required — compose refuses to start without it. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=604800

# Add the Vercel frontend URL here once deployed.
CORS_ORIGINS=http://localhost:3000
